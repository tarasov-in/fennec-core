# Fennec Core - NPM Ignore
# Исключаем ненужные файлы из npm пакета для уменьшения размера

# Source files (публикуем только dist/)
src/
stories/
example/

# Tests
**/*.test.js
**/*.test.jsx
**/*.spec.js
**/*.spec.jsx
__tests__/
__mocks__/

# Documentation (оставляем только README.md)
REFACTORING_PLAN.md
PROGRESS.md
ARCHITECTURE.md
FIELD_REFACTORING_PLAN.md
MOBILE_REFACTORING_NOTES.md
RELEASE_CHECKLIST.md
SUMMARY.md
STORYBOOK_SETUP.md

# Development files
.storybook/
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.travis.yml
.github/
.gitlab-ci.yml
circle.yml

# Build artifacts (кроме dist/)
build/
coverage/
.nyc_output/
storybook-static/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Temporary files
tmp/
temp/
*.tmp

# Node modules (не должно быть в репозитории, но на всякий случай)
node_modules/

# Lock files (оставляем только в репозитории)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Что ВКЛЮЧАЕТСЯ в пакет:
# - dist/ (built files)
# - README.md
# - CHANGELOG.md
# - MIGRATION.md
# - DEPRECATION.md
# - LICENSE
# - package.json
